{
  "manifest_version": 3,
  "name": "Donloader",
  "description": "Скачивание видео с YouTube через Donloader",
  "version": "1.0",
  "permissions": [],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://127.0.0.1:18734/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
